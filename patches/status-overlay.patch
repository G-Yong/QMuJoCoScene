+  char label[30] = {'\0'};
+  if (sim->loadrequest) {
+    std::snprintf(label, sizeof(label), "LOADING...");
+  } else if (!sim->run) {
+    if (sim->scrub_index == 0) {
+      std::snprintf(label, sizeof(label), "PAUSE");
+    } else {
+      std::snprintf(label, sizeof(label), "PAUSE (%d)", sim->scrub_index);
